TELEGRAM_BOT_TOKEN=your_token_here
OPENAI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=avatar_chunks
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://avatar:avatar@postgres:5432/avatar
LLM_MODEL=gpt-4o-mini
AVATAR_NAME=Digital Avatar
REFERENCE_VIDEO_PATH=app/data/reference_circle.mp4
REFERENCE_VOICE_PATH=app/data/reference.wav
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=ru
# Coqui XTTS: set to 1 to skip the interactive [y/n] prompt (you accept CPML for non-commercial use, or have a commercial license — https://coqui.ai/cpml)
COQUI_TOS_AGREED=1
# Optional: app/main.py sets HF_HUB_DISABLE_XET=1 by default so XTTS files avoid xethub (DNS issues on cas-bridge.xethub.hf.co). Set to 0 to try XET.
# HF_HUB_DISABLE_XET=0
WAV2LIP_REPO_PATH=
WAV2LIP_CHECKPOINT_PATH=
