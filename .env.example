TELEGRAM_BOT_TOKEN=your_token_here
OPENAI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=avatar_chunks
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://avatar:avatar@postgres:5432/avatar
LLM_MODEL=gpt-4o-mini
AVATAR_NAME=Digital Avatar
REFERENCE_VIDEO_PATH=app/data/reference_circle.mp4
# Optional JSON with multiple circle video profiles (video/range/crop anchor).
# REFERENCE_PROFILES_PATH=app/data/video_profiles.json
# Optional fixed still image for fallback video mode (best framing).
# If set and file exists, fallback ignores FALLBACK_STILL_SECOND extraction.
# REFERENCE_STILL_PATH=app/data/reference_still.jpg
REFERENCE_VOICE_PATH=app/data/reference.wav
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=ru
# Fallback still-frame moment in seconds (used when Wav2Lip is unavailable).
FALLBACK_STILL_SECOND=1.0
# Fallback live clip duration in seconds (used when REFERENCE_STILL_PATH is empty).
FALLBACK_CLIP_SECONDS=1.8
# Coqui XTTS: set to 1 to skip the interactive [y/n] prompt (you accept CPML for non-commercial use, or have a commercial license — https://coqui.ai/cpml)
COQUI_TOS_AGREED=1
# Optional: app/main.py sets HF_HUB_DISABLE_XET=1 by default so XTTS files avoid xethub (DNS issues on cas-bridge.xethub.hf.co). Set to 0 to try XET.
# HF_HUB_DISABLE_XET=0
WAV2LIP_REPO_PATH=
WAV2LIP_CHECKPOINT_PATH=

# Local Qwen + LoRA (train_lora_sft output). Requires NVIDIA GPU + CUDA. Set false on CPU-only hosts.
LOCAL_LLM_ENABLED=true
LOCAL_LLM_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_LLM_ADAPTER_PATH=app/data/models/igor-lora/adapter
# LOCAL_LLM_MAX_NEW_TOKENS=240
